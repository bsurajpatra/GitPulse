{
  "name": "gitmatch-desktop",
  "version": "1.1.0",
  "main": "main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "cd renderer && npm run build && cd .. && electron-builder",
    "postinstall": "cd renderer && npm install"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-is-dev": "^3.0.1",
    "electron-store": "^8.2.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "npm-run-all": "^4.1.5"
  },
  "build": {
    "appId": "com.github.analytics.desktop",
    "productName": "GitMatch",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GitMatch",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "allowElevation": true,
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp"
    },
    "files": [
      "main/**/*",
      "server/**/*",
      "services/**/*",
      "analytics/**/*",
      "store/**/*",
      ".env",
      "renderer/dist/**/*",
      "package.json",
      "!.env.local",
      "!.env.development.local",
      "!.env.test.local",
      "!.env.production.local",
      "!store/**/*.json",
      "!**/cache",
      "!**/session",
      "!**/sessions",
      "!**/.cache",
      "!**/.sessions",
      "!**/*.log"
    ]
  }
}
